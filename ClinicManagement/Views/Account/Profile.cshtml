@model ClinicManagement.Models.ViewModels.ProfileViewModel
@{ ViewData["Title"] = "My Profile"; ViewData["Breadcrumb"] = "Profile"; }
<div class="page-header"><h1><i class="bi bi-person-gear me-2"></i>My Profile</h1></div>
<div class="row">
    <div class="col-md-4">
        <div class="card text-center p-4">
            @if (Model.ProfilePicture != null)
            { <img src="@Model.ProfilePicture" class="profile-avatar mx-auto" /> }
            else
            { <div class="profile-avatar-placeholder mx-auto">@Model.FullName?.Substring(0,1)</div> }
            <h4 class="mt-3">@Model.FullName</h4>
            <p class="text-muted">@Model.Email</p>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">Edit Profile</div>
            <div class="card-body">
                <form asp-action="Profile" method="post" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label class="form-label">Full Name</label>
                            <input asp-for="FullName" class="form-control" />
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="form-label">Phone</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label class="form-label">Date of Birth</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="form-label">Avatar</label>
                            <input asp-for="Avatar" type="file" class="form-control" accept="image/*" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Address</label>
                        <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                    </div>
                    <hr />
                    <h6>Change Password</h6>
                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label class="form-label">Current</label>
                            <input asp-for="CurrentPassword" class="form-control" />
                        </div>
                        <div class="col-md-4 form-group">
                            <label class="form-label">New</label>
                            <input asp-for="NewPassword" class="form-control" />
                        </div>
                        <div class="col-md-4 form-group">
                            <label class="form-label">Confirm</label>
                            <input asp-for="ConfirmNewPassword" class="form-control" />
                        </div>
                    </div>
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save Changes</button>
                </form>
            </div>
        </div>
    </div>
</div>
