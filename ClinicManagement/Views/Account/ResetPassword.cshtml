@model ClinicManagement.Models.ViewModels.ResetPasswordViewModel
@{ ViewData["Title"] = "Reset Password"; Layout = null; }
<!DOCTYPE html>
<html><head>
<meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Reset Password</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="login-page">
    <div class="login-card">
        <div class="logo"><i class="bi bi-shield-lock"></i></div>
        <h2>Reset Password</h2>
        <p>Enter your new password</p>
        <form asp-action="ResetPassword" method="post">
            <input asp-for="Token" type="hidden" />
            <input asp-for="Email" type="hidden" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <div class="form-group">
                <label class="form-label">New Password</label>
                <input asp-for="Password" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary w-100" style="padding:12px">Reset Password</button>
        </form>
    </div>
</div>
</body></html>
