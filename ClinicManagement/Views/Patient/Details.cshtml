@model ClinicManagement.Models.Entities.Patient
@{ ViewData["Title"] = Model.User.FullName; ViewData["Breadcrumb"] = "Patient Details"; }
<div class="page-header">
    <h1><i class="bi bi-person me-2"></i>@Model.User.FullName</h1>
    <a href="/Patient/Edit/@Model.PatientId" class="btn btn-primary btn-sm"><i class="bi bi-pencil"></i> Edit</a>
</div>
<div class="row g-3">
    <div class="col-md-4">
        <div class="card p-4 text-center">
            <div class="profile-avatar-placeholder mx-auto">@Model.User.FullName.Substring(0,1)</div>
            <h4 class="mt-3">@Model.User.FullName</h4>
            <p class="text-muted">@Model.User.Email</p>
            <div class="mt-2">
                @if (Model.BloodType.HasValue) { <span class="badge-status badge-scheduled">@Model.BloodType</span> }
                @if (!string.IsNullOrEmpty(Model.InsuranceProvider)) { <span class="badge-status badge-confirmed mt-1">@Model.InsuranceProvider</span> }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <!-- Tabs -->
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#info">Info</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#appointments">Appointments</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#records">Records</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#invoices">Invoices</a></li>
        </ul>
        <div class="tab-content card" style="border-top:none;border-top-left-radius:0;border-top-right-radius:0">
            <div class="tab-pane fade show active p-3" id="info">
                <div class="row mb-2"><div class="col-4 text-muted">Phone</div><div class="col-8">@(Model.User.PhoneNumber ?? "N/A")</div></div>
                <div class="row mb-2"><div class="col-4 text-muted">Gender</div><div class="col-8">@(Model.User.Gender?.ToString() ?? "N/A")</div></div>
                <div class="row mb-2"><div class="col-4 text-muted">DOB</div><div class="col-8">@(Model.User.DateOfBirth?.ToString("MMM dd, yyyy") ?? "N/A")</div></div>
                <div class="row mb-2"><div class="col-4 text-muted">Address</div><div class="col-8">@(Model.User.Address ?? "N/A")</div></div>
                <div class="row mb-2"><div class="col-4 text-muted">Emergency</div><div class="col-8">@(Model.EmergencyContactName ?? "N/A") - @(Model.EmergencyContactPhone ?? "")</div></div>
                <div class="row mb-2"><div class="col-4 text-muted">Insurance</div><div class="col-8">@(Model.InsuranceNumber ?? "N/A") (@(Model.InsuranceProvider ?? "None"))</div></div>
                @if (!string.IsNullOrEmpty(Model.MedicalHistory))
                { <div class="row mb-2"><div class="col-4 text-muted">History</div><div class="col-8">@Model.MedicalHistory</div></div> }
            </div>
            <div class="tab-pane fade p-3" id="appointments">
                @if (Model.Appointments.Any())
                {
                    <table class="table"><thead><tr><th>Date</th><th>Doctor</th><th>Status</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var a in Model.Appointments.OrderByDescending(a => a.AppointmentDate))
                    { <tr><td>@a.AppointmentDate.ToString("MMM dd, yyyy") @a.AppointmentTime.ToString(@"hh\:mm")</td><td>@a.Doctor.User.FullName</td><td><span class="badge-status badge-@a.Status.ToString().ToLower()">@a.Status</span></td><td><a href="/Appointment/Details/@a.AppointmentId" class="btn btn-sm btn-secondary">View</a></td></tr> }
                    </tbody></table>
                }
                else { <div class="empty-state"><i class="bi bi-calendar-x"></i><h5>No appointments</h5></div> }
            </div>
            <div class="tab-pane fade p-3" id="records">
                @if (Model.MedicalRecords.Any())
                {
                    <div class="timeline">
                    @foreach (var r in Model.MedicalRecords.OrderByDescending(r => r.CreatedAt))
                    {
                        <div class="timeline-item">
                            <strong>@r.CreatedAt.ToString("MMM dd, yyyy")</strong> — @r.Diagnosis.Substring(0, Math.Min(80, r.Diagnosis.Length))...
                            <a href="/MedicalRecord/Details/@r.RecordId" class="btn btn-sm btn-secondary ms-2">View</a>
                        </div>
                    }
                    </div>
                }
                else { <div class="empty-state"><i class="bi bi-clipboard2-x"></i><h5>No records</h5></div> }
            </div>
            <div class="tab-pane fade p-3" id="invoices">
                @if (Model.Invoices.Any())
                {
                    <table class="table"><thead><tr><th>Date</th><th>Amount</th><th>Status</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var inv in Model.Invoices.OrderByDescending(i => i.InvoiceDate))
                    { <tr><td>@inv.InvoiceDate.ToString("MMM dd, yyyy")</td><td>$@inv.TotalAmount</td><td><span class="badge-status badge-@inv.PaymentStatus.ToString().ToLower()">@inv.PaymentStatus</span></td><td><a href="/Invoice/Details/@inv.InvoiceId" class="btn btn-sm btn-secondary">View</a></td></tr> }
                    </tbody></table>
                }
                else { <div class="empty-state"><i class="bi bi-receipt-cutoff"></i><h5>No invoices</h5></div> }
            </div>
        </div>
    </div>
</div>
