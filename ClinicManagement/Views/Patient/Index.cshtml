@model IEnumerable<ClinicManagement.Models.Entities.Patient>
@{ ViewData["Title"] = "Patients"; ViewData["Breadcrumb"] = "Patients"; }
<div class="page-header">
    <h1><i class="bi bi-people me-2"></i>Patients</h1>
    <a href="/Patient/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Patient</a>
</div>
<div class="card">
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-md-4"><input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search name, phone, insurance..." /></div>
            <div class="col-md-2"><button class="btn btn-primary">Search</button></div>
        </form>
        <div class="table-wrapper">
            <table class="table data-table">
                <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Blood Type</th><th>Insurance</th><th>Actions</th></tr></thead>
                <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><strong>@p.User.FullName</strong></td>
                        <td>@p.User.Email</td>
                        <td>@(p.User.PhoneNumber ?? "N/A")</td>
                        <td>@(p.BloodType?.ToString() ?? "N/A")</td>
                        <td>@(p.InsuranceProvider ?? "N/A")</td>
                        <td>
                            <a href="/Patient/Details/@p.PatientId" class="btn btn-sm btn-secondary"><i class="bi bi-eye"></i></a>
                            <a href="/Patient/Edit/@p.PatientId" class="btn btn-sm btn-primary"><i class="bi bi-pencil"></i></a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
