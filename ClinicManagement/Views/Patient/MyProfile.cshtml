@model ClinicManagement.Models.Entities.Patient
@{ ViewData["Title"] = "My Profile"; ViewData["Breadcrumb"] = "My Profile"; }
<div class="page-header"><h1><i class="bi bi-person me-2"></i>My Profile</h1></div>
<div class="row g-3">
    <div class="col-md-4">
        <div class="card p-4 text-center">
            <div class="profile-avatar-placeholder mx-auto">@Model.User.FullName.Substring(0,1)</div>
            <h4 class="mt-3">@Model.User.FullName</h4>
            <p class="text-muted">@Model.User.Email</p>
        </div>
    </div>
    <div class="col-md-8">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#myinfo">My Info</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#myappts">Appointments</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#myrecords">Records</a></li>
        </ul>
        <div class="tab-content card" style="border-top:none;border-top-left-radius:0;border-top-right-radius:0">
            <div class="tab-pane fade show active p-3" id="myinfo">
                <div class="row mb-2"><div class="col-4 text-muted">Phone</div><div class="col-8">@(Model.User.PhoneNumber ?? "N/A")</div></div>
                <div class="row mb-2"><div class="col-4 text-muted">Blood Type</div><div class="col-8">@(Model.BloodType?.ToString() ?? "N/A")</div></div>
                <div class="row mb-2"><div class="col-4 text-muted">Insurance</div><div class="col-8">@(Model.InsuranceProvider ?? "None")</div></div>
            </div>
            <div class="tab-pane fade p-3" id="myappts">
                @if (Model.Appointments?.Any() == true)
                {
                    <table class="table"><thead><tr><th>Date</th><th>Doctor</th><th>Status</th></tr></thead>
                    <tbody>
                    @foreach (var a in Model.Appointments.OrderByDescending(a => a.AppointmentDate))
                    { <tr><td>@a.AppointmentDate.ToString("MMM dd, yyyy")</td><td>@a.Doctor.User.FullName</td><td><span class="badge-status badge-@a.Status.ToString().ToLower()">@a.Status</span></td></tr> }
                    </tbody></table>
                }
                else { <div class="empty-state"><i class="bi bi-calendar-x"></i><h5>No appointments yet</h5></div> }
            </div>
            <div class="tab-pane fade p-3" id="myrecords">
                @if (Model.MedicalRecords?.Any() == true)
                {
                    @foreach (var r in Model.MedicalRecords.OrderByDescending(r => r.CreatedAt))
                    { <div class="p-3 mb-2" style="border:1px solid var(--border);border-radius:8px"><strong>@r.CreatedAt.ToString("MMM dd, yyyy")</strong><p class="mb-0">@r.Diagnosis</p></div> }
                }
                else { <div class="empty-state"><i class="bi bi-clipboard2-x"></i><h5>No medical records</h5></div> }
            </div>
        </div>
    </div>
</div>
