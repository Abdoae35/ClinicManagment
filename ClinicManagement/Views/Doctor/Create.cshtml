@model ClinicManagement.Models.ViewModels.DoctorCreateViewModel
@{ ViewData["Title"] = "Add Doctor"; ViewData["Breadcrumb"] = "Add Doctor"; }
<div class="page-header"><h1><i class="bi bi-person-plus me-2"></i>Add Doctor</h1></div>
<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post" data-loading>
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <h6 class="mb-3">Account Information</h6>
            <div class="row">
                <div class="col-md-4 form-group"><label class="form-label">Full Name *</label><input asp-for="FullName" class="form-control" /><span asp-validation-for="FullName" class="text-danger"></span></div>
                <div class="col-md-4 form-group"><label class="form-label">Email *</label><input asp-for="Email" class="form-control" /><span asp-validation-for="Email" class="text-danger"></span></div>
                <div class="col-md-4 form-group"><label class="form-label">Phone</label><input asp-for="PhoneNumber" class="form-control" /></div>
            </div>
            <hr />
            <h6 class="mb-3">Professional Information</h6>
            <div class="row">
                <div class="col-md-4 form-group">
                    <label class="form-label">Specialization *</label>
                    <select asp-for="SpecializationId" class="form-select">
                        <option value="">-- Select --</option>
                        @foreach (var s in Model.Specializations!) { <option value="@s.SpecializationId">@s.Name</option> }
                    </select>
                </div>
                <div class="col-md-4 form-group"><label class="form-label">License Number *</label><input asp-for="LicenseNumber" class="form-control" /></div>
                <div class="col-md-4 form-group"><label class="form-label">Years of Experience</label><input asp-for="YearsOfExperience" type="number" class="form-control" /></div>
            </div>
            <div class="row">
                <div class="col-md-4 form-group"><label class="form-label">Consultation Fee</label><input asp-for="ConsultationFee" type="number" step="0.01" class="form-control" /></div>
                <div class="col-md-4 form-group"><label class="form-label">Working Days</label><input asp-for="WorkingDays" class="form-control" placeholder="Monday,Tuesday,..." /></div>
            </div>
            <div class="form-group"><label class="form-label">Bio</label><textarea asp-for="Bio" class="form-control" rows="3"></textarea></div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create Doctor</button>
                <a href="/Doctor" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
