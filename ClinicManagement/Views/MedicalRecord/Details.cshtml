@model ClinicManagement.Models.Entities.MedicalRecord
@{ ViewData["Title"] = "Medical Record"; ViewData["Breadcrumb"] = "Record Details"; }
<div class="page-header">
    <h1><i class="bi bi-clipboard2-check me-2"></i>Medical Record #@Model.RecordId</h1>
    <a href="/MedicalRecord/Print/@Model.RecordId" class="btn btn-secondary btn-sm" target="_blank"><i class="bi bi-printer"></i> Print</a>
</div>
<div class="row g-3">
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header">Record Details</div>
            <div class="card-body">
                <div class="row mb-3"><div class="col-4 text-muted">Patient</div><div class="col-8"><a href="/Patient/Details/@Model.PatientId">@Model.Patient.User.FullName</a></div></div>
                <div class="row mb-3"><div class="col-4 text-muted">Doctor</div><div class="col-8">@Model.Doctor.User.FullName</div></div>
                <div class="row mb-3"><div class="col-4 text-muted">Date</div><div class="col-8">@Model.CreatedAt.ToString("MMM dd, yyyy")</div></div>
                <div class="row mb-3"><div class="col-4 text-muted">Diagnosis</div><div class="col-8">@Model.Diagnosis</div></div>
                @if (!string.IsNullOrEmpty(Model.TreatmentPlan))
                { <div class="row mb-3"><div class="col-4 text-muted">Treatment Plan</div><div class="col-8">@Model.TreatmentPlan</div></div> }
                @if (!string.IsNullOrEmpty(Model.LabResults))
                { <div class="row mb-3"><div class="col-4 text-muted">Lab Results</div><div class="col-8">@Model.LabResults</div></div> }
                @if (Model.FollowUpDate.HasValue)
                { <div class="row mb-3"><div class="col-4 text-muted">Follow-Up</div><div class="col-8">@Model.FollowUpDate.Value.ToString("MMM dd, yyyy")</div></div> }
                @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                { <div class="row mb-3"><div class="col-4 text-muted">Attachment</div><div class="col-8"><a href="@Model.AttachmentPath" target="_blank" class="btn btn-sm btn-secondary"><i class="bi bi-download"></i> Download</a></div></div> }
            </div>
        </div>
        @if (Model.PrescriptionItems.Any())
        {
            <div class="card">
                <div class="card-header">Prescription</div>
                <div class="card-body">
                    <table class="table"><thead><tr><th>Medicine</th><th>Dosage</th><th>Frequency</th><th>Duration</th><th>Instructions</th></tr></thead>
                    <tbody>
                    @foreach (var p in Model.PrescriptionItems)
                    { <tr><td>@p.MedicineName</td><td>@p.Dosage</td><td>@p.Frequency</td><td>@p.Duration</td><td>@p.Instructions</td></tr> }
                    </tbody></table>
                </div>
            </div>
        }
    </div>
</div>
