@model ClinicManagement.Models.ViewModels.ClinicCreateViewModel
@{ ViewData["Title"] = "Add Clinic"; ViewData["Breadcrumb"] = "Add Clinic"; }
<div class="page-header"><h1><i class="bi bi-plus-lg me-2"></i>Add Clinic</h1></div>
<div class="card"><div class="card-body">
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <div class="row">
        <div class="col-md-6 form-group"><label class="form-label">Name *</label><input asp-for="Name" class="form-control" /></div>
        <div class="col-md-6 form-group"><label class="form-label">Specialization</label>
            <select asp-for="SpecializationId" class="form-select"><option value="">None</option>
            @if(Model.Specializations!=null){foreach(var s in Model.Specializations){<option value="@s.SpecializationId">@s.Name</option>}}</select></div>
    </div>
    <div class="row">
        <div class="col-md-3 form-group"><label class="form-label">Floor</label><input asp-for="Floor" class="form-control" /></div>
        <div class="col-md-3 form-group"><label class="form-label">Room</label><input asp-for="RoomNumber" class="form-control" /></div>
        <div class="col-md-3 form-group"><label class="form-label">Phone</label><input asp-for="Phone" class="form-control" /></div>
    </div>
    <div class="form-group"><label class="form-label">Description</label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
    <a href="/Clinic" class="btn btn-secondary ms-2">Cancel</a>
</form></div></div>
