@model IEnumerable<ClinicManagement.Models.Entities.Clinic>
@{ ViewData["Title"] = "Clinics"; ViewData["Breadcrumb"] = "Clinics"; }
<div class="page-header">
    <h1><i class="bi bi-building me-2"></i>Clinics</h1>
    <a href="/Clinic/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Clinic</a>
</div>
<div class="card">
    <div class="card-body">
        <table class="table data-table">
            <thead><tr><th>Name</th><th>Floor</th><th>Room</th><th>Phone</th><th>Specialization</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td><strong>@c.Name</strong></td><td>@(c.Floor ?? "N/A")</td><td>@(c.RoomNumber ?? "N/A")</td><td>@(c.Phone ?? "N/A")</td>
                    <td>@(c.Specialization?.Name ?? "N/A")</td>
                    <td><span class="badge-status @(c.IsActive ? "badge-completed" : "badge-cancelled")">@(c.IsActive ? "Active" : "Inactive")</span></td>
                    <td>
                        <a href="/Clinic/Edit/@c.ClinicId" class="btn btn-sm btn-primary"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" method="post" style="display:inline" onsubmit="return confirm('Deactivate this clinic?')">
                            <input type="hidden" name="id" value="@c.ClinicId" />
                            <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
