@{
    ViewData["Title"] = "Hospital CMS";
    Layout = null;
}
<!DOCTYPE html>
<html><head>
<meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Hospital Clinic Management System</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="login-page" style="flex-direction:column;gap:24px;text-align:center">
    <div class="login-card" style="max-width:520px">
        <div class="logo" style="width:80px;height:80px;font-size:36px"><i class="bi bi-hospital"></i></div>
        <h2 style="font-size:28px">Hospital Clinic Management</h2>
        <p style="font-size:15px">Streamlined healthcare management for clinics, doctors, and patients.</p>
        <div class="d-grid gap-2 mt-4">
            <a href="/Account/Login" class="btn btn-primary" style="padding:14px;font-size:16px"><i class="bi bi-box-arrow-in-right me-2"></i>Sign In</a>
            <a href="/Account/Register" class="btn btn-secondary" style="padding:14px;font-size:16px"><i class="bi bi-person-plus me-2"></i>Register as Patient</a>
        </div>
        <div class="mt-4" style="border-top:1px solid var(--border);padding-top:20px">
            <p class="text-muted mb-2" style="font-size:12px">Demo Credentials</p>
            <div class="row g-2" style="font-size:12px;text-align:left">
                <div class="col-6"><strong>Admin:</strong> admin@hospital.com</div><div class="col-6">Admin@123456</div>
                <div class="col-6"><strong>Doctor:</strong> doctor1@hospital.com</div><div class="col-6">Doctor@123456</div>
                <div class="col-6"><strong>Reception:</strong> reception@hospital.com</div><div class="col-6">Recept@123456</div>
                <div class="col-6"><strong>Patient:</strong> patient1@hospital.com</div><div class="col-6">Patient@123456</div>
            </div>
        </div>
    </div>
</div>
</body></html>
