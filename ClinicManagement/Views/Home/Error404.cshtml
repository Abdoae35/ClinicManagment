@{
    ViewData["Title"] = "Page Not Found";
    Layout = null;
}
<!DOCTYPE html>
<html><head>
<meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>404 - Not Found</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="login-page">
    <div class="login-card" style="text-align:center">
        <div style="font-size:80px;color:var(--warning);margin-bottom:16px"><i class="bi bi-exclamation-triangle"></i></div>
        <h2 style="font-size:48px;font-weight:800;color:var(--text)">404</h2>
        <p style="font-size:16px;color:var(--text-muted)">The page you're looking for doesn't exist.</p>
        <a href="/" class="btn btn-primary mt-3"><i class="bi bi-house"></i> Back to Home</a>
