@model IEnumerable<ClinicManagement.Models.Entities.Notification>
@{ ViewData["Title"] = "Notifications"; ViewData["Breadcrumb"] = "Notifications"; }
<div class="page-header">
    <h1><i class="bi bi-bell me-2"></i>Notifications</h1>
    <form asp-action="MarkAllRead" method="post"><button class="btn btn-secondary btn-sm"><i class="bi bi-check-all"></i> Mark All Read</button></form>
</div>
<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            @foreach (var n in Model)
            {
                <div class="d-flex align-items-start gap-3 p-3 @(!n.IsRead ? "" : "")" style="border-bottom:1px solid var(--border);@(!n.IsRead ? "background:rgba(0,119,182,0.03)" : "")">
                    <div style="width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;@(n.Type == ClinicManagement.Models.Enums.NotificationType.Appointment ? "background:rgba(0,119,182,0.1);color:var(--primary)" : n.Type == ClinicManagement.Models.Enums.NotificationType.Alert ? "background:rgba(230,57,70,0.1);color:var(--danger)" : "background:rgba(45,198,83,0.1);color:var(--success)")">
                        <i class="bi @(n.Type == ClinicManagement.Models.Enums.NotificationType.Appointment ? "bi-calendar-check" : n.Type == ClinicManagement.Models.Enums.NotificationType.Alert ? "bi-exclamation-triangle" : "bi-info-circle")"></i>
                    </div>
                    <div style="flex:1">
                        <strong style="font-size:14px">@n.Title</strong>
                        @if (!n.IsRead) { <span class="badge-status badge-scheduled ms-2" style="font-size:10px">New</span> }
                        <p class="mb-0 text-muted" style="font-size:13px">@n.Message</p>
                        <small class="text-muted">@n.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state"><i class="bi bi-bell-slash"></i><h5>No notifications</h5></div>
        }
    </div>
</div>
