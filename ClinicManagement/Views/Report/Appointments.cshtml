@model ClinicManagement.Models.ViewModels.ReportFilterViewModel
@{ ViewData["Title"] = "Appointments Report"; ViewData["Breadcrumb"] = "Appointments Report"; }
<div class="page-header"><h1><i class="bi bi-calendar-check me-2"></i>Appointments Report</h1></div>
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2"><label class="form-label">From</label><input name="from" type="date" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control" /></div>
            <div class="col-md-2"><label class="form-label">To</label><input name="to" type="date" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control" /></div>
            <div class="col-md-2"><label class="form-label">Doctor</label>
                <select name="doctorId" class="form-select"><option value="">All</option>
                @if(Model.Doctors!=null){foreach(var d in Model.Doctors){<option value="@d.DoctorId" selected="@(Model.DoctorId==d.DoctorId)">@d.User.FullName</option>}}</select></div>
            <div class="col-md-2"><label class="form-label">Status</label>
                <select name="status" class="form-select"><option value="">All</option>
                @foreach(var s in Enum.GetValues<ClinicManagement.Models.Enums.AppointmentStatus>()){<option value="@((int)s)" selected="@(Model.Status==(int?)s)">@s</option>}</select></div>
            <div class="col-md-1"><button class="btn btn-primary w-100">Filter</button></div>
            <div class="col-md-2"><a href="/Report/ExportAppointments?from=@Model.FromDate?.ToString("yyyy-MM-dd")&to=@Model.ToDate?.ToString("yyyy-MM-dd")&doctorId=@Model.DoctorId&status=@Model.Status" class="btn btn-success w-100"><i class="bi bi-file-earmark-excel"></i> Excel</a></div>
        </form>
    </div>
</div>
@if (Model.ReportData != null)
{
    var appointments = (IEnumerable<ClinicManagement.Models.Entities.Appointment>)Model.ReportData;
    <div class="card"><div class="card-body">
    <table class="table data-table"><thead><tr><th>Date</th><th>Time</th><th>Patient</th><th>Doctor</th><th>Status</th><th>Reason</th></tr></thead>
    <tbody>
    @foreach(var a in appointments)
    { <tr><td>@a.AppointmentDate.ToString("MMM dd, yyyy")</td><td>@a.AppointmentTime.ToString(@"hh\:mm")</td><td>@a.Patient.User.FullName</td><td>@a.Doctor.User.FullName</td><td><span class="badge-status badge-@a.Status.ToString().ToLower()">@a.Status</span></td><td>@a.ReasonForVisit</td></tr> }
    </tbody></table></div></div>
}
