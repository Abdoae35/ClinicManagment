@model IEnumerable<ClinicManagement.Models.Entities.Appointment>
@{ ViewData["Title"] = "Appointments Calendar"; ViewData["Breadcrumb"] = "Appointments"; }
<div class="page-header">
    <h1><i class="bi bi-calendar-check me-2"></i>Appointments</h1>
    <div>
        <a href="/Appointment/List" class="btn btn-secondary btn-sm"><i class="bi bi-list-ul"></i> List View</a>
        <a href="/Appointment/Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> New</a>
    </div>
</div>
<div class="card">
    <div class="card-body">
        <div id="calendar"></div>
    </div>
</div>
@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            headerToolbar: { left: 'prev,next today', center: 'title', right: 'dayGridMonth,timeGridWeek,timeGridDay' },
            events: @Html.Raw(ViewBag.Events),
            eventClick: function(info) { info.jsEvent.preventDefault(); if(info.event.url) window.location.href = info.event.url; },
            height: 700
        });
        calendar.render();
    });
</script>
}
