@model ClinicManagement.Models.ViewModels.AppointmentCreateViewModel
@{ ViewData["Title"] = "New Appointment"; ViewData["Breadcrumb"] = "New Appointment"; }
<div class="page-header"><h1><i class="bi bi-calendar-plus me-2"></i>New Appointment</h1></div>
<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post" data-loading>
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <div class="row">
                <div class="col-md-6 form-group">
                    <label class="form-label">Patient *</label>
                    <select asp-for="PatientId" class="form-select">
                        <option value="">-- Select Patient --</option>
                        @if (Model.Patients != null) { foreach (var p in Model.Patients) { <option value="@p.PatientId">@p.User.FullName</option> } }
                    </select>
                </div>
                <div class="col-md-6 form-group">
                    <label class="form-label">Specialization</label>
                    <select id="specSelect" class="form-select" onchange="loadDoctors(this.value)">
                        <option value="">-- Select Specialization --</option>
                        @if (Model.Specializations != null) { foreach (var s in Model.Specializations) { <option value="@s.SpecializationId">@s.Name</option> } }
                    </select>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 form-group">
                    <label class="form-label">Doctor *</label>
                    <select asp-for="DoctorId" id="doctorSelect" class="form-select" onchange="var d=document.getElementById('dateInput');if(d.value)loadSlots(this.value,d.value)">
                        <option value="">-- Select Doctor --</option>
                    </select>
                </div>
                <div class="col-md-4 form-group">
                    <label class="form-label">Date *</label>
                    <input asp-for="AppointmentDate" type="date" id="dateInput" class="form-control" onchange="var s=document.getElementById('doctorSelect');if(s.value)loadSlots(s.value,this.value)" />
                </div>
                <div class="col-md-4 form-group">
                    <label class="form-label">Time Slot *</label>
                    <select asp-for="AppointmentTime" id="slotSelect" class="form-select">
                        <option value="">-- Select Date & Doctor first --</option>
                    </select>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 form-group">
                    <label class="form-label">Clinic</label>
                    <select asp-for="ClinicId" class="form-select">
                        <option value="">-- Optional --</option>
                        @if (Model.Clinics != null) { foreach (var c in Model.Clinics) { <option value="@c.ClinicId">@c.Name</option> } }
                    </select>
                </div>
                <div class="col-md-4 form-group">
                    <label class="form-label">Duration (min)</label>
                    <input asp-for="DurationMinutes" type="number" class="form-control" />
                </div>
            </div>
            <div class="form-group"><label class="form-label">Reason for Visit</label><textarea asp-for="ReasonForVisit" class="form-control" rows="2"></textarea></div>
            <div class="form-group"><label class="form-label">Notes</label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Book Appointment</button>
            <a href="/Appointment" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
