@model ClinicManagement.Models.ViewModels.AppointmentEditViewModel
@{ ViewData["Title"] = "Edit Appointment"; ViewData["Breadcrumb"] = "Edit Appointment"; }
<div class="page-header"><h1><i class="bi bi-pencil me-2"></i>Edit Appointment</h1></div>
<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input asp-for="AppointmentId" type="hidden" /><input asp-for="PatientId" type="hidden" /><input asp-for="DoctorId" type="hidden" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <div class="row">
                <div class="col-md-4 form-group"><label class="form-label">Date</label><input asp-for="AppointmentDate" type="date" class="form-control" /></div>
                <div class="col-md-4 form-group"><label class="form-label">Time</label><input asp-for="AppointmentTime" type="time" class="form-control" /></div>
                <div class="col-md-4 form-group"><label class="form-label">Duration</label><input asp-for="DurationMinutes" type="number" class="form-control" /></div>
            </div>
            <div class="row">
                <div class="col-md-4 form-group">
                    <label class="form-label">Status</label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<ClinicManagement.Models.Enums.AppointmentStatus>()" class="form-select"></select>
                </div>
                <div class="col-md-4 form-group">
                    <label class="form-label">Clinic</label>
                    <select asp-for="ClinicId" class="form-select">
                        <option value="">None</option>
                        @if (Model.Clinics != null) { foreach (var c in Model.Clinics) { <option value="@c.ClinicId">@c.Name</option> } }
                    </select>
                </div>
            </div>
            <div class="form-group"><label class="form-label">Reason</label><textarea asp-for="ReasonForVisit" class="form-control" rows="2"></textarea></div>
            <div class="form-group"><label class="form-label">Notes</label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
            <a href="/Appointment/Details/@Model.AppointmentId" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
