@model ClinicManagement.Models.Entities.Appointment
@{ ViewData["Title"] = "Appointment Details"; ViewData["Breadcrumb"] = "Appointment Details"; }
<div class="page-header">
    <h1><i class="bi bi-calendar-check me-2"></i>Appointment #@Model.AppointmentId</h1>
    <div>
        @if (Model.Status != ClinicManagement.Models.Enums.AppointmentStatus.Completed && Model.Status != ClinicManagement.Models.Enums.AppointmentStatus.Cancelled
            && (User.IsInRole("Admin") || User.IsInRole("Receptionist") || User.IsInRole("Doctor")))
        {
            <a href="/Appointment/Edit/@Model.AppointmentId" class="btn btn-primary btn-sm"><i class="bi bi-pencil"></i> Edit</a>
        }
    </div>
</div>
<div class="row g-3">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">Appointment Information</div>
            <div class="card-body">
                <div class="row mb-3"><div class="col-4 text-muted">Status</div><div class="col-8"><span class="badge-status badge-@Model.Status.ToString().ToLower()">@Model.Status</span></div></div>
                <div class="row mb-3"><div class="col-4 text-muted">Date</div><div class="col-8">@Model.AppointmentDate.ToString("dddd, MMM dd, yyyy")</div></div>
                <div class="row mb-3"><div class="col-4 text-muted">Time</div><div class="col-8">@Model.AppointmentTime.ToString(@"hh\:mm") (@Model.DurationMinutes min)</div></div>
                <div class="row mb-3"><div class="col-4 text-muted">Patient</div><div class="col-8"><a href="/Patient/Details/@Model.PatientId">@Model.Patient.User.FullName</a></div></div>
                <div class="row mb-3"><div class="col-4 text-muted">Doctor</div><div class="col-8"><a href="/Doctor/Details/@Model.DoctorId">@Model.Doctor.User.FullName</a></div></div>
                @if (Model.Clinic != null)
                { <div class="row mb-3"><div class="col-4 text-muted">Clinic</div><div class="col-8">@Model.Clinic.Name (Room @Model.Clinic.RoomNumber)</div></div> }
                @if (!string.IsNullOrEmpty(Model.ReasonForVisit))
                { <div class="row mb-3"><div class="col-4 text-muted">Reason</div><div class="col-8">@Model.ReasonForVisit</div></div> }
                @if (!string.IsNullOrEmpty(Model.Notes))
                { <div class="row mb-3"><div class="col-4 text-muted">Notes</div><div class="col-8">@Model.Notes</div></div> }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header">Actions</div>
            <div class="card-body d-grid gap-2">
                @if (Model.Status == ClinicManagement.Models.Enums.AppointmentStatus.Scheduled)
                {
                    <form asp-action="UpdateStatus" method="post"><input type="hidden" name="id" value="@Model.AppointmentId" /><input type="hidden" name="status" value="@((int)ClinicManagement.Models.Enums.AppointmentStatus.Confirmed)" /><button class="btn btn-success w-100"><i class="bi bi-check-circle"></i> Confirm</button></form>
                }
                @if (Model.Status == ClinicManagement.Models.Enums.AppointmentStatus.Confirmed)
                {
                    <form asp-action="UpdateStatus" method="post"><input type="hidden" name="id" value="@Model.AppointmentId" /><input type="hidden" name="status" value="@((int)ClinicManagement.Models.Enums.AppointmentStatus.Completed)" /><button class="btn btn-success w-100"><i class="bi bi-check-all"></i> Complete</button></form>
                }
                @if (Model.Status != ClinicManagement.Models.Enums.AppointmentStatus.Cancelled && Model.Status != ClinicManagement.Models.Enums.AppointmentStatus.Completed)
                {
                    <form asp-action="Cancel" method="post" onsubmit="return confirm('Cancel this appointment?')"><input type="hidden" name="id" value="@Model.AppointmentId" /><button class="btn btn-danger w-100"><i class="bi bi-x-circle"></i> Cancel</button></form>
                }
                @if (Model.Status == ClinicManagement.Models.Enums.AppointmentStatus.Completed && Model.MedicalRecord == null)
                {
                    <a href="/MedicalRecord/Create/@Model.AppointmentId" class="btn btn-primary w-100"><i class="bi bi-clipboard2-plus"></i> Add Medical Record</a>
                }
                @if (Model.MedicalRecord != null)
                {
                    <a href="/MedicalRecord/Details/@Model.MedicalRecord.RecordId" class="btn btn-secondary w-100"><i class="bi bi-clipboard2-check"></i> View Medical Record</a>
                }
                @if (Model.Invoice != null)
                {
                    <a href="/Invoice/Details/@Model.Invoice.InvoiceId" class="btn btn-secondary w-100"><i class="bi bi-receipt"></i> View Invoice</a>
                }
            </div>
        </div>
    </div>
</div>
