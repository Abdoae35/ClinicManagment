@model ClinicManagement.Models.ViewModels.DoctorDashboardViewModel
@{ ViewData["Title"] = "Doctor Dashboard"; ViewData["Breadcrumb"] = "My Dashboard"; }
<div class="page-header"><h1><i class="bi bi-grid-1x2 me-2"></i>My Dashboard</h1></div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="stat-card primary">
            <div class="stat-icon"><i class="bi bi-calendar-check"></i></div>
            <div class="stat-value">@Model.TodayAppointments</div>
            <div class="stat-label">Today's Appointments</div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="stat-card warning">
            <div class="stat-icon"><i class="bi bi-clipboard2-pulse"></i></div>
            <div class="stat-value">@Model.PendingRecords</div>
            <div class="stat-label">Pending Medical Records</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><i class="bi bi-clock me-2"></i>Today's Appointments</div>
            <div class="card-body">
                @if (Model.TodayAppointmentsList.Any())
                {
                    <table class="table">
                        <thead><tr><th>Time</th><th>Patient</th><th>Status</th><th>Actions</th></tr></thead>
                        <tbody>
                        @foreach (var a in Model.TodayAppointmentsList)
                        {
                            <tr>
                                <td>@a.AppointmentTime.ToString(@"hh\:mm")</td>
                                <td>@a.Patient.User.FullName</td>
                                <td><span class="badge-status badge-@a.Status.ToString().ToLower()">@a.Status</span></td>
                                <td>
                                    <a href="/Appointment/Details/@a.AppointmentId" class="btn btn-sm btn-secondary">View</a>
                                    @if (a.Status == ClinicManagement.Models.Enums.AppointmentStatus.Completed && a.MedicalRecord == null)
                                    { <a href="/MedicalRecord/Create/@a.AppointmentId" class="btn btn-sm btn-primary">Add Record</a> }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
                else { <div class="empty-state"><i class="bi bi-calendar-x"></i><h5>No appointments today</h5></div> }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header"><i class="bi bi-calendar-week me-2"></i>My Schedule</div>
            <div class="card-body">
                @foreach (var s in Model.WeekSchedule.Where(s => s.IsActive))
                {
                    <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid var(--border)">
                        <strong>@s.DayOfWeek</strong>
                        <span>@s.StartTime.ToString(@"hh\:mm") - @s.EndTime.ToString(@"hh\:mm")</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
